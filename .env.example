# Database — libra-backend 의 docker-compose 와 같은 Postgres 공유
DATABASE_URL=postgresql://libra:libra@localhost:5432/libra

# Anthropic
ANTHROPIC_API_KEY=
LIBRA_LLM_PROVIDER=anthropic
LIBRA_DOMAIN_AGENTS_ENABLED=true
LIBRA_LLM_TIMEOUT_SECONDS=45
LIBRA_LLM_REQUEST_TIMEOUT_SECONDS=45
# 모델 이름 — design_spec_v1.md §1.4
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6
LIBRA_ANTHROPIC_MODEL=claude-sonnet-4-6

# Server
HOST=0.0.0.0
PORT=8000

# S3 (보고서 / parquet)
S3_BUCKET=libra-reports-dev
AWS_REGION=ap-northeast-2

# 로깅
LOG_LEVEL=INFO
LOG_FORMAT=console   # console (dev) | json (prod)
