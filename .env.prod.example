COMPOSE_PROJECT_NAME=libra-prod

# EC2 local data path. scripts/ec2-bootstrap.sh creates this path.
LIBRA_APP_DATA_ROOT=/opt/libra/data

# Agent systemd runtime. GitHub Actions deploy and systemd health checks assume port 8000.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
LOG_FORMAT=json

# Optional compose/image values for local promotion or backend compose stacks.
LIBRA_AGENT_IMAGE=libra-agent:latest
LIBRA_BACKEND_IMAGE=libra-backend:latest

# Agent LLM provider. Do not commit real API keys.
LIBRA_LLM_PROVIDER=anthropic
LIBRA_ANTHROPIC_MODEL=claude-sonnet-4-5
LIBRA_LLM_TIMEOUT_SECONDS=45
LIBRA_LLM_REQUEST_TIMEOUT_SECONDS=45

# Enables the domain council adapters. The deploy venv must install .[domain-agents].
LIBRA_DOMAIN_AGENTS_ENABLED=true
ANTHROPIC_API_KEY=CHANGE_ME_ANTHROPIC_API_KEY

# libra-agent LangGraph checkpoint database.
# This must be PostgreSQL and is used only by AsyncPostgresSaver for runtime
# checkpoints/resume. Do not use backend RDS MySQL LIBRA_DB_* values here.
DATABASE_URL=postgresql://libra_agent:CHANGE_ME_CHECKPOINTER_PASSWORD@CHANGE_ME_POSTGRES_HOST:5432/libra_agent_checkpoints

# Agent knowledge cache / S3 fallback.
# Reader order: local KNOWLEDGE_CACHE_DIR first, then S3 if S3_BUCKET is set.
KNOWLEDGE_CACHE_DIR=/opt/libra/knowledge/current
KNOWLEDGE_S3_PREFIX=knowledge/current
AWS_REGION=ap-northeast-2
S3_BUCKET=

# Optional. Keep disabled unless the EC2 deployment also mounts or ships libra-ingest.
LIBRA_INGEST_REFRESH_ENABLED=false
LIBRA_INGEST_REFRESH_MODE=live
LIBRA_INGEST_ROOT=/opt/libra/libra-ingest
LIBRA_INGEST_OUT_DIR=/opt/libra/data/knowledge/agent_refresh
LIBRA_INGEST_RSS_LIMIT=3
LIBRA_INGEST_DART_LIMIT=5
LIBRA_INGEST_REPORT_LIMIT=3
LIBRA_INGEST_SKIP_ARTICLE_BODY=true

# Public entrypoint. Use ":80" before DNS is ready, or "api.example.com" after DNS points to EC2.
LIBRA_DOMAIN=:80
LIBRA_UPSTREAM=127.0.0.1:8000
LIBRA_HTTP_PORT=80
LIBRA_HTTPS_PORT=443

# Backend RDS MySQL. These values are not read by the agent LangGraph checkpointer.
LIBRA_DB_HOST=CHANGE_ME_RDS_MYSQL_HOST
LIBRA_DB_PORT=3306
LIBRA_DB_NAME=libra
LIBRA_DB_USER=CHANGE_ME_RDS_MYSQL_USER
LIBRA_DB_PASSWORD=CHANGE_ME_RDS_MYSQL_PASSWORD

# Backend/shared S3 aliases. Agent knowledge reader uses AWS_REGION/S3_BUCKET above.
LIBRA_S3_REGION=ap-northeast-2
LIBRA_S3_BUCKET=

# Korea Investment API. Keep empty until libra-backend needs it.
LIBRA_KIS_REAL_APP_KEY=
LIBRA_KIS_REAL_APP_SECRET=
LIBRA_KIS_REAL_ACCOUNT_NO=
LIBRA_KIS_REAL_PRODUCT_CODE=01
LIBRA_KIS_USER_AGENT=LIBRA-EC2/1.0
