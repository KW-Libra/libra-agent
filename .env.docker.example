COMPOSE_PROJECT_NAME=libra-local

LIBRA_DOCKER_DATA_ROOT=D:/docker-data/libra

MYSQL_DATABASE=libra
MYSQL_USER=libra
MYSQL_PASSWORD=libra_local_password
MYSQL_ROOT_PASSWORD=libra_root_password
MYSQL_PORT=3307

MINIO_ROOT_USER=libra
MINIO_ROOT_PASSWORD=libra_minio_password
MINIO_CONSOLE_PORT=9001
MINIO_API_PORT=9000
MINIO_BUCKET=libra-local

LIBRA_API_PORT=8080

LIBRA_AGENT_BACKEND=ollama
LIBRA_AGENT_MODEL=dolphin-llama3:8b
LIBRA_OLLAMA_HOST=http://host.docker.internal:11434
LIBRA_AGENT_STATE_DIR=/app/outputs/libra_state

LIBRA_KIS_REAL_APP_KEY=
LIBRA_KIS_REAL_APP_SECRET=
LIBRA_KIS_REAL_ACCOUNT_NO=
LIBRA_KIS_REAL_PRODUCT_CODE=01
LIBRA_KIS_DEMO_APP_KEY=
LIBRA_KIS_DEMO_APP_SECRET=
LIBRA_KIS_DEMO_ACCOUNT_NO=
LIBRA_KIS_DEMO_PRODUCT_CODE=01
